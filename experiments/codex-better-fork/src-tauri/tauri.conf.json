{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "codex-better-fork",
  "version": "0.1.0",
  "identifier": "io.github.pauloportella.codex-better-fork",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "codex-better-fork",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns"
    ]
  }
}
